  "publicApiSurface": [
    "/api/slack/ingest - Slack feedback ingestion endpoint",
    "/api/slack/reaction - Reaction-based feedback capture",
    "/api/ext/semantic-search - External semantic search API",
    "@feedback/ai - AI agents and embeddings package",
    "@feedback/database - Drizzle ORM schema and utilities",
    "@feedback/redis - Redis client helpers",
    "SemanticSearchAgent - Matches feedback to feature requests",
    "RequestCreatorAgent - Generates feature request details",
    "ThreadSummarizationAgent - Extracts pain points from Slack threads",
    "AreaInsightsAgent - Analyzes product areas and generates reports",
    "processFeedbackWorkflow - Main feedback processing workflow",
    "generateAreaInsightsWorkflow - Area insights generation workflow",
    "weeklyDigestWorkflow - Weekly Slack digest workflow"
  ]
